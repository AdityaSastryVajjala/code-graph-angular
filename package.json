{
  "name": "codegraph-angular",
  "version": "0.1.0",
  "description": "Graph-based code intelligence platform for Angular workspaces",
  "type": "commonjs",
  "main": "dist/cli/index.js",
  "bin": {
    "codegraph": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "jest --testPathPattern=tests/e2e",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "clean": "rimraf dist"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@angular/compiler": "^17.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chokidar": "^3.5.3",
    "commander": "^12.0.0",
    "fast-glob": "^3.3.2",
    "neo4j-driver": "^5.0.0",
    "typescript": "^5.4.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.0",
    "ts-jest": "^29.1.0"
  }
}
